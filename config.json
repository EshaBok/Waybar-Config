{
  "include": "~/.config/waybar/modules",
  "layer": "top",
  "position": "top",
  "height": 14,
  "margin-left": 10,
  "margin-right": 10,
  "margin-top": 2,
  
  "modules-left": [
    "custom/menu",
    "custom/separator#blank_2",
    "clock",
    "custom/separator#blank_2",
    "hyprland/window"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],
  
  "modules-right": [
    "custom/swaync",
    "custom/separator#blank",
    "tray",
    "custom/separator#blank",
    "mpris",
    "custom/separator#blank",
    "pulseaudio",
    "custom/separator#blank",
    "custom/power"
  ],

  "custom/power": {
    "format": " ",
    "icon-size": 20,
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M - %d/%b}",
    "tooltip": false
  }
}



